# Копируй в .env и заполни значения

DATABASE_URL=postgresql+psycopg://drivee:drivee@localhost:5432/drivee

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# При таймаутах/«Connection closed» попробуйте:
# SMTP_PORT=465
# SMTP_USE_SSL=true
# (порт 465 — сразу SSL, часто проходит там, где режут 587)
# SMTP_FORCE_IPV4=false  — только если нужен чистый IPv6
SMTP_USER=you@gmail.com
SMTP_PASS=app_password
SMTP_USE_SSL=false
SMTP_FORCE_IPV4=true
SMTP_TIMEOUT=30
SMTP_DEBUG=false

# Канал писем: auto | resend | smtp. Если сеть режет SMTP — используйте Resend (HTTP по 443).
MAIL_PROVIDER=auto
# Resend: ключ с https://resend.com (Settings → API Keys).
RESEND_API_KEY=
# From: свой подтверждённый домен (noreply@вашдомен) или onboarding@resend.dev для теста.
MAIL_FROM=Drivee <onboarding@resend.dev>

# Проверка PDF-квитанции об оплате через LLM (OpenRouter, https://openrouter.ai).
# Арендатор прикрепляет PDF из банка — модель сверяет сумму/назначение платежа.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# Вход в админку (один пользователь-владелец).
# AUTH_PASSWORD задайте свой; AUTH_SECRET — длинная случайная строка
# (python -c "import secrets; print(secrets.token_hex(32))").
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me
AUTH_SECRET=change_me_to_a_long_random_hex

# Для сборки фронта в Docker (URL API в браузере пользователя)
VITE_API_URL=http://localhost:8000
