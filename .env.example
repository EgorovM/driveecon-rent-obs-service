# Копируй в .env и заполни значения

DATABASE_URL=postgresql+psycopg://drivee:drivee@localhost:5432/drivee

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# При таймаутах/«Connection closed» попробуйте:
# SMTP_PORT=465
# SMTP_USE_SSL=true
# (порт 465 — сразу SSL, часто проходит там, где режут 587)
# SMTP_FORCE_IPV4=false  — только если нужен чистый IPv6
SMTP_USER=you@gmail.com
SMTP_PASS=app_password
SMTP_USE_SSL=false
SMTP_FORCE_IPV4=true
SMTP_TIMEOUT=30
SMTP_DEBUG=false

FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# Для сборки фронта в Docker (URL API в браузере пользователя)
VITE_API_URL=http://localhost:8000
